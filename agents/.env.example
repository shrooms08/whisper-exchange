# Required. Get a free key at https://dashboard.helius.dev/ — the public
# devnet RPC rate-limits getProgramAccounts hard enough that the e2e
# flow can't complete in its window.
HELIUS_API_KEY=

SUPPLIER_KEYPAIR=./keys/supplier-solana.json
BUYER_KEYPAIR=./keys/buyer-solana.json
SIGNAL_MODE=mock

# Base layer RPC. Defaults to https://devnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
# (constructed from HELIUS_API_KEY) when unset. Override only if you want a
# different provider (e.g. Triton, QuickNode).
# BASE_RPC=

# MagicBlock ephemeral rollup RPC. Defaults to https://devnet.magicblock.app/
# when unset.
# ER_RPC=https://devnet.magicblock.app/

# Set true to route purchases via the MagicBlock ephemeral rollup
# (init_purchase_for_delegation + delegate_for_purchase → purchase_listing_private
# on ER → settle_purchase on base). False uses the base-layer
# purchase_listing_public escape hatch (single-tx, public). Default: false.
USE_PRIVATE_PURCHASE=false
