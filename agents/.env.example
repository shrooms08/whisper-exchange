# Required. Get a free key at https://dashboard.helius.dev/ — the public
# devnet RPC rate-limits getProgramAccounts hard enough that the e2e
# flow can't complete in its window.
# Day 1.5 (2026-05-04): outgoing Helius requests are blocked until credits
# reset; we keep the key populated for the supplier.ts/buyer.ts gate check
# but route all RPC traffic through BASE_RPC below.
HELIUS_API_KEY=

# Day 1.5: primary RPC for agents + scripts. supplier.ts:52 / buyer.ts:48
# already honour BASE_RPC, falling back to Helius when unset.
BASE_RPC=https://your-quicknode-devnet-endpoint/

SUPPLIER_KEYPAIR=./keys/supplier-solana.json
BUYER_KEYPAIR=./keys/buyer-solana.json
SIGNAL_MODE=mock

# --- Day 2: multi-agent profiles ----------------------------------------------
# All AGENT_* vars are read by supplier.ts / buyer.ts. With none of them set,
# the agents behave as the original single-agent flow (handle from
# SUPPLIER_HANDLE/BUYER_HANDLE, default keystore paths, no category/price
# filters). Set them to differentiate behaviour per-agent in launch-multi.sh.
#
# AGENT_HANDLE                  identifier used in registration + every log line
# AGENT_SOLANA_KEYPAIR          path to the agent's Solana keypair JSON
# AGENT_X25519_KEYPAIR          path to the agent's x25519 keypair JSON
#
# Supplier-only:
# AGENT_SIGNAL_CATEGORIES       CSV (e.g. WHALE,MEV) — supplier ignores other categories
# AGENT_PRICE_LAMPORTS          single price for every listing this agent creates
#
# Buyer-only:
# AGENT_BUY_CATEGORIES          CSV — buyer purchases only listings in these categories
# AGENT_MAX_PRICE_LAMPORTS      ceiling — buyer skips any listing priced ≥ this
# AGENT_MIN_REPUTATION          integer numerator threshold; 0 = no gate, >0 = require
#                                supplier.reputation_num ≥ this AND reputation_den > 0
# Example launch-multi.sh values:
#   night-oracle: AGENT_SIGNAL_CATEGORIES=WHALE,MEV  AGENT_PRICE_LAMPORTS=2400000000
#   dawn-watcher: AGENT_SIGNAL_CATEGORIES=MINT,INSDR,IMBAL  AGENT_PRICE_LAMPORTS=1800000000
#   alpha-hunter: AGENT_BUY_CATEGORIES=WHALE,MEV,IMBAL  AGENT_MAX_PRICE_LAMPORTS=3000000000  AGENT_MIN_REPUTATION=0
#   cipher-rook : AGENT_BUY_CATEGORIES=MINT,INSDR,WHALE  AGENT_MAX_PRICE_LAMPORTS=2500000000  AGENT_MIN_REPUTATION=4

# MagicBlock ephemeral rollup RPC. Defaults to https://devnet.magicblock.app/
# when unset.
# ER_RPC=https://devnet.magicblock.app/

# Set true to route purchases via the MagicBlock ephemeral rollup
# (init_purchase_for_delegation + delegate_for_purchase → purchase_listing_private
# on ER → settle_purchase on base). False uses the base-layer
# purchase_listing_public escape hatch (single-tx, public). Default: false.
USE_PRIVATE_PURCHASE=false

# Frontier track — real Helius signal pipeline (mainnet signals, devnet
# marketplace). When USE_REAL_SIGNALS=true, supplier polls the webhook
# receiver instead of the mock signal generator. Default false keeps the
# pre-Frontier path identical for cold E2E reproducibility.
USE_REAL_SIGNALS=false

# Public URL of the webhook receiver (ngrok during dev, Cloudflare Tunnel or
# direct public IP in production). Helius POSTs events here. Path is
# /helius/events. Required when USE_REAL_SIGNALS=true.
WEBHOOK_PUBLIC_URL=

# Local port the webhook receiver listens on. Default 4000.
WEBHOOK_RECEIVER_PORT=4000

# Shared secret. Helius sends this as the Authorization header on every
# webhook POST; receiver rejects requests where it doesn't match. Generate
# a fresh value with: openssl rand -hex 32. Never commit.
HELIUS_WEBHOOK_AUTH_HEADER=<generate-with-openssl-rand-hex-32>
