# Server-side env for the Whisper Exchange dashboard. Copy to .env.local and fill in.
# Never commit .env.local — app/.gitignore covers .env*.

# Primary RPC. As of Day 1.5 this is QuickNode devnet — Helius free-tier
# credits exhausted, quota resets May 21. lib/chain.ts prefers this if set.
QUICKNODE_RPC_URL=<your-quicknode-devnet-https-endpoint>

# Fallback RPC. Used only when QUICKNODE_RPC_URL is unset. Will be the
# primary again once the Helius quota resets.
HELIUS_API_KEY=<your-helius-api-key>

# If neither is set, lib/chain.ts falls back to https://api.devnet.solana.com
# (public RPC — gPA calls will likely 429 under any real load).

# Day 5 — client-exposed RPC URL for the Solana Wallet Adapter on
# /become-an-agent. Same value as QUICKNODE_RPC_URL above; the NEXT_PUBLIC_
# prefix ships it to the browser bundle so the wallet adapter's
# ConnectionProvider can use it for genesis-hash + balance reads. If unset,
# the wallet adapter falls back to clusterApiUrl('devnet') (public RPC).
# Acceptable to expose: the same URL is already shipped to clients via
# /api/chain reads.
NEXT_PUBLIC_QUICKNODE_RPC_URL=<your-quicknode-devnet-https-endpoint>
